# Язык ответов агента: en | ru (выбирается в `npm run setup`, дефолт ru).
# Управляет инструкцией 05-language, локалью даты (now) и сидом CORE при init-vault.
AGENT_LANGUAGE=ru

# Провайдер модели: ollama | opencode | codex.
#   ollama/opencode — OpenAI-совместимы (chat/completions), статичный API-ключ ниже.
#   codex — личная подписка OpenAI (ChatGPT): Responses API + OAuth, ключ НЕ нужен (см. ниже).
MODEL_PROVIDER=ollama

# Ollama Cloud (если MODEL_PROVIDER=ollama)
OLLAMA_API_KEY=ollama-...
OLLAMA_MODEL=deepseek-v4-pro
# Окно контекста: НЕ завышай — компактация считает порог от него (overflow-риск).
OLLAMA_CONTEXT_WINDOW=131072

# OpenCode Zen/Go (если MODEL_PROVIDER=opencode) — https://opencode.ai/auth
OPENCODE_API_KEY=
OPENCODE_MODEL=opencode-go/deepseek-v4-pro
OPENCODE_CONTEXT_WINDOW=131072

# OpenAI по подписке ChatGPT (если MODEL_PROVIDER=codex). Вход: `iva login`
# (по ссылке+коду) или `iva login --browser`. Токен → data/codex-auth.json (0600, не в .env).
# API-ключ НЕ нужен. Модель выбирается в `iva config` из реального списка подписки.
CODEX_MODEL=gpt-5.5
CODEX_CONTEXT_WINDOW=272000

# Браузер agent-browser: потолок вывода (защита окна контекста).
AGENT_BROWSER_MAX_OUTPUT=24000

# Telegram-бот (для канала и дайджеста)
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_BOT_USERNAME=my_bot
TELEGRAM_WEBHOOK_SECRET_TOKEN=придумай_длинную_строку
# БЕЗОПАСНОСТЬ: бот отвечает ТОЛЬКО этим user ID (через запятую). Пусто = не отвечает никому.
# Свой ID: напиши @userinfobot или запусти `npm run setup` (автоопределение).
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_DIGEST_CHAT_ID=         # твой chat_id для утреннего дайджеста

# Deepgram — транскрипция голоса/видео из Telegram (nova-3)
# Ключ: https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=
# Язык распознавания. multi = автоопределение (ru/uz/en и др.).
DEEPGRAM_LANGUAGE=multi

# Веб-поиск — инструмент web_search. Выбери провайдера и впиши его ключ.
# Без ключа выбранного провайдера поиск не работает (DuckDuckGo с серверного IP даёт капчу).
#   tavily   https://app.tavily.com                  free ~1000/мес, без карты, есть answer (рекомендуем)
#   exa      https://dashboard.exa.ai                free ~20k/мес, без карты
#   parallel https://platform.parallel.ai            стартовые кредиты, без карты
#   brave    https://api-dashboard.search.brave.com  нужна карта (идентификация), ~$5/мес кредит
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
BRAVE_API_KEY=
EXA_API_KEY=
PARALLEL_API_KEY=

# Поиск по памяти (memory_search). По умолчанию grep = встроенный BM25 (node:sqlite FTS5) +
# близость по графу связей — ноль зависимостей, ноль внешних ключей, работает на $4-боксе.
#   hybrid = дополнительно dense-эмбеддинги (RRF-слияние с BM25) через ОДИН внешний ключ.
# Для hybrid задай ОДИН ключ (Jina — no-train/EU/дёшево, или DeepInfra — дешевле, BGE-M3),
# индекс собирает ночной doctor (или вручную: node --env-file=.env scripts/memory/embed-index.ts).
MEMORY_SEARCH_MODE=grep
JINA_API_KEY=
DEEPINFRA_API_KEY=
# MEMORY_EMBED_PROVIDER=jina        # переопределить автовыбор (jina|deepinfra)
# MEMORY_EMBED_MODEL=jina-embeddings-v3
# MEMORY_EMBED_URL=http://127.0.0.1:11434/v1/embeddings  # любой OpenAI-совместимый эндпоинт
#                                   # (напр. локальный Ollama) — тогда внешний ключ не нужен

# Часовой пояс (IANA). Используется для дат daily-транскрипта, систем­ных
# таймеров памяти и динамической инструкции now. Пробрасывается в TZ.
ASSISTANT_TIMEZONE=Asia/Almaty

# Каталог ЖИВОГО vault (память + Obsidian + git-бэкап). Относительный или абсолютный.
# Отдельный приватный git-репо; создаётся из vault-template/ через `npm run init-vault`.
ASSISTANT_VAULT_DIR=vault

# Хранилище задач (необязательно; по умолчанию ./data)
ASSISTANT_DATA_DIR=data

# Порт локального eve-сервера. Дефолт 8723 — непопсовый: 3000/8000/8080 на типовом
# VPS обычно заняты (docker и пр.). Сервер слушает его, клиенты ходят на него же.
IVA_PORT=8723

# Куда ходят cron/poll-клиенты (необязательно; по умолчанию http://127.0.0.1:${IVA_PORT})
ASSISTANT_HOST=http://127.0.0.1:8723
# ASSISTANT_BEARER=                # если eve-канал в проде требует bearer-токен
